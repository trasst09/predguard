{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "*.html",
        "styles.css",
        "browser-app.js",
        "config.js",
        "data.js",
        "data/**",
        "utils/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
