HOST=127.0.0.1
PORT=3000

# Supabase mode in server.js is enabled automatically when all three values are set.
# The server accepts either SUPABASE_* vars or the NEXT_PUBLIC_* equivalents below.
SUPABASE_URL=https://wxjkvharpdudmketsjeb.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
SUPABASE_SECRET_KEY=sb_secret_your_secret_key

# Optional frontend-style aliases. The current Node server also reads these.
NEXT_PUBLIC_SUPABASE_URL=https://wxjkvharpdudmketsjeb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
